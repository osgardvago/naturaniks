---
import Text from "../atoms/Text.astro";
import { colors } from "../../design-system/colors.js";
import prot from "../../../public/assets/exported/prot.webp";
import { Image } from "astro:assets";
import Button from "../atoms/Button.astro";
import ListItem from "./ListItem.astro";
---

<div
    class="benefit-card bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow"
>
    <div class="flex items-center mb-6">
        <div
            class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mr-4"
        >
            <Image
                src={prot}
                alt="Prot"
                width={500}
                height={500}
                class="object-cover"
            />
        </div>
        <Text type="h3" color={colors.dark}>Beneficios Prot</Text>
    </div>

    <ul class="space-y-4">
        <ListItem
            title="Completo en proteinas"
            desc="Contiene todos los aminoacidos necesarios para la regeneración celular"
            color="amber"
        />
        <ListItem
            title="Fuente de balance de energía"
            desc="Alimenta, regenera y energiza todas las celulas de tu cuerpo"
            color="amber"
        />
        <ListItem
            title="Salud integral"
            desc="Aumento y/o conservación de músculos, ayuda a recobrarse mas rápido de enfermedades y lesiones"
            color="amber"
        />
        <ListItem
            title="Energy Booster"
            desc="Energia sostenida para todas tus actividades"
            color="amber"
        />
    </ul>

    <div class="mt-6">
        <a href="/category/prot">
            <Button variant="secondary" className="w-full">
                Explorar Prot →
            </Button>
        </a>
    </div>
</div>
