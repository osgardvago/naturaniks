---
import Text from "../atoms/Text.astro";
import { colors } from "../../design-system/colors.js";

interface Props {
    title: string;
    desc: string;
    color: string;
}

const { title, desc, color } = Astro.props;
---

<li class="flex items-start">
    <span class="text-3xl text-green-500  mr-3 mt-1">✓</span>
    <div>
        <Text class="text-lg" type="body" color={colors.dark} style="font-size: 1.2em;">
            {title}
        </Text>
        <Text type="body" color={colors.gray} style="color: #777;">
            {desc}
        </Text>
    </div>
</li>
