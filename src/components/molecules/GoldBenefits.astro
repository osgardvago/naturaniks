---
import { Image } from "astro:assets";
import Text from "../atoms/Text.astro";
import Button from "../atoms/Button.astro";
import { colors } from "../../design-system/colors.js";
import makhana from "../../../public/assets/exported/makhana.webp";
import ListItem from "./ListItem.astro";
---

<div
    class="benefit-card bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-shadow"
>
    <div class="flex items-center mb-6">
        <div
            class="w-14 h-14 bg-amber-100 rounded-full flex items-center justify-center mr-4"
        >
            <Image
                src={makhana}
                alt="Makhana"
                width={500}
                height={500}
                class="object-cover"
            />
        </div>
        <Text type="h3" color={colors.dark}>Beneficios Gold</Text>
    </div>
    <ul class="space-y-4">
        <ListItem
            title="Anti inflamatorio"
            desc="Control de la inflamación con ingredientes efectivos y naturales"
            color="green"
        />
        <ListItem
            title="Rico en antioxidantes"
            desc="Ayuda a combatir el envejecimiento prematuro"
            color="green"
        />
        <ListItem
            title="Amigable con tu corazón"
            desc="Sin sodio, sin azucar, "
            color="green"
        />
        <ListItem
            title="Conveniente"
            desc="Fácil de portar y consumir"
            color="green"
        />
    </ul>
    <div class="mt-6">
        <a href="/category/gold">
            <Button variant="secondary" className="w-full">
                Explorar Gold →
            </Button>
        </a>
    </div>
</div>
