---
/* =====================
   IMPORTS & ASSETS
   ===================== */
import Layout from "../layouts/Layout.astro";
import Hero from "../components/organisms/Hero.astro";
import { colors } from "../design-system/colors.js";
import Text from "../components/atoms/Text.astro";
import GoldBenefits from "../components/molecules/GoldBenefits.astro";
import ProtBenefits from "../components/molecules/ProtBenefits.astro";
import FeaturedProducts from "../components/organisms/FeaturedProducts.astro";
import Footer from "../components/organisms/Footer.astro";
import { Image } from "astro:assets";
import heroImage from "../../public/assets/shared/hero-banner.webp";
import CategoryCards from "../components/molecules/CategoryCards.astro";

const description = "Naturaniks ofrece suplementos alimenticios que ayudan a que te sientas mejor."

const promises = [
  {
    icon: "🌱",
    title: "Ingredientes naturales",
    text: `Solo usamos ingredientes creados por la tierra, producidos por agricultores expertos.`,
  },
  {
    icon: "🧂",
    title: "Nada agregado, Nada removido",
    text: `Sin conservantes ni colorantes artificiales. Con la misma pureza que
            tu bisabuela aprobaría.`,
  },
  {
    icon: "🛡️",
    title: "Pensando en el bien de todos",
    text: `Creemos que hacer cosas valiosas empieza por hacerlas para el bien, lo hacemos por nuestra familia, lo compartimos con todos, si es bueno para nuestra familia, es bueno para ti`,
  },
];

const structuredData = JSON.stringify(
  {
    "@context": "https://schema.org",
    "@type": ["WebSite", "OnlineStore"],
    "name": "Naturaniks",
    "url": "https://www.naturaniks.pages.dev/",
    description,
    "inLanguage": "es-MX",
    "areaServed": "MX",
    "publisher": {
      "@type": "Organization",
      "name": "Naturaniks",
      "url": "https://www.naturaniks.pages.dev/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.naturaniks.pages.dev/assets/shared/logo.webp"
      },
      "sameAs": [
        "https://www.facebook.com/people/Farm-Pure/61566574773069/",
        "https://in.linkedin.com/company/slb-overseas-llp",
        "https://www.instagram.com/Naturaniksofficial/"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+52 3336374169",
        "contactType": "Ventas",
        "areaServed": "MX",
        "availableLanguage": "es"
      }
    },
    "mainEntity": {
      "@type": "WebPage",
      "@id": "https://www.naturaniks.pages.dev/#home",
      "name": "Home",
      "about": [
        {
          "@type": "CollectionPage",
          "name": "Prot Category",
          "description": "Explora los productos Naturaniks",
          "url": "https://www.naturaniks.pages.dev/category/prot",
          "image": "https://www.naturaniks.pages.dev/assets/exported/prot.webp"
        },
        {
          "@type": "CollectionPage",
          "name": "Gold Category",
          "description": "Compra la mejor combinación de ingredientes naturales anti inflamatorios .",
          "url": "https://www.naturaniks.pages.dev/category/gold",
          "image": "https://www.naturaniks.pages.dev/assets/exported/gold.webp"
        }
      ],
      "primaryImageOfPage": {
        "@type": "ImageObject",
        "url": "https://www.naturaniks.pages.dev/assets/shared/hero-banner.webp",
        "caption": "Nutraceuticos naturales para sentirse mejor"
      }
    }
  }
)
---

<Layout title="Home of Naturaniks | Gold | Prot", description={description}>
  <!-- ===========================
       STRUCTURED DATA FOR SEO
       =========================== -->
  <Fragment slot="head">
    <!-- Google site verification, remove when you're deploying -->
    <meta
      name="Naturaniks suplementos alimenticios naturales"
      content="Tienda online de suplementos alimenticios naturales: Naturaniks Gold (antiinflamatorio a base de curcuma, jengibre y ajo) Naturaniks Prot (agregado de alga espirulina, albumina de huevo y levadura de cerveza rico en proteinas)"
    />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <script type="application/ld+json" set:html={structuredData} />
  </Fragment>

  <!-- ===========================
       HERO SECTION
       =========================== -->
  <Hero>
    <div
      class="bg-gradient-to-br from-white to-green-50 overflow-hidden relative">
      <div class="mx-auto max-w-7xl px-4 pt-6">
        <div class="grid items-center gap-12 md:grid-cols-2">
          <!-- Left: Hero Text Content -->
          <div class="flex flex-col text-center md:items-start md:text-left">
            <div class="inline-block">
              <span
                class="animate-pulse rounded-full bg-green-50 px-4 py-2 text-sm font-semibold text-green-700"
              >
                🌱 Puro & Natural
              </span>
            </div>

            <Text
              type="h1"
              color={colors.dark}
              className="hero-title pt-4 pb-4 text-4xl font-bold leading-tight md:text-5xl lg:text-6xl"
            >
              Herencia, tradición y sabiduria global,<br />
              <span
                class="bg-gradient-to-br from-yellow-300 to-green-300 bg-clip-text text-transparent"
              >
                para tu salud
              </span>
            </Text>

            <div class="flex justify-center md:justify-start">
              <Text
                type="body"
                color={colors.gray}
                className="max-w-xl text-lg leading-relaxed md:text-xl"
              >
                Por muchas generaciones, hemos sabido que la naturaleza nos provee de todo lo que necesitamos. En <strong>Naturaniks</strong>, creemos en recuperar esa sabiduría ancestral y complementarla con el conocimiento científico actual para ofrecerte productos elaborados con lo mejor de la naturaleza, de forma práctica, efectiva y perfectamente adaptada a nuestro estilo de vida moderno.
              </Text>
            </div>

            <CategoryCards />
          </div>

          <!-- Right: Hero Image -->
          <div class="flex justify-center md:justify-end mb-10">
            <Image
              src={heroImage}
              alt="Suplementos alimenticios de origen natural"
              class="max-w-full w-full object-contain drop-shadow-2xl transition-transform duration-500 hover:scale-110"
              width={750}
              height={1000}
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- ===========================
       OUR STORY SECTION
       =========================== -->
    <section class="bg-white px-4 py-16" aria-labelledby="story-heading">
      <div class="mx-auto max-w-6xl">
        <div class="grid md:grid-cols-2 gap-12 items-center mb-10">
          <div class="order-2 md:order-1">
            <div class="space-y-6">
              <div class="inline-block">
                <span
                  class="text-sm font-semibold text-green-700 tracking-wide uppercase"
                >
                  Nuestro viaje
                </span>
              </div>
              <Text
                type="h2"
                color={colors.dark}
                id="story-heading"
                className="text-3xl md:text-4xl font-bold leading-tight"
              >
                Consebido para nuestra familia, compartido contigo
              </Text>
              <div class="space-y-4 text-gray-700 leading-relaxed">
                <p>
                  Comenzó con una pregunta: <em
                    class="text-green-400 italic text-lg font-bold"
                    >¿Como ayudar al cuerpo a controlar la inflamación usando solo productos naturales?</em
                  >
                </p>
                <p>
                  Investigación, sabiduría familiar y ensayos nos ayudaron a encontrar la combinación exacta de ingredientes tradicionales que en conjunto ayudan efectivamente a controlar la inflamación de manera <strong
                    class="text-slate-900 font-semibold"
                    > efectiva con cero efectos secundarios negativos. </strong
                  >.
                </p>
                <p>
                  El cuidado mutuo y el autocuidado personal son la razón de ser de nuestros esfuerzos; cada producto que ofrecemos lo hacemos inicialmente para nosotros, probamos sus beneficios y luego lo compartimos.
                </p>
              </div>

            </div>
          </div>
          <div class="order-1 md:order-2">
            <div
              class="bg-gradient-to-br from-green-100 to-yellow-200 rounded-2xl p-8 shadow-lg"
            >
              <div class="grid grid-cols-2 gap-4">
                <div class="bg-white rounded-xl p-6 text-center shadow-sm">
                  <div class="text-3xl font-bold text-amber-300">100%</div>
                  <div class="text-sm text-gray-600 mt-2">Natural</div>
                </div>
                <div class="bg-white rounded-xl p-6 text-center shadow-sm">
                  <div class="md:text-2xl font-bold sm:text-1xl text-amber-300">Menos de 5</div>
                  <div class="text-sm text-gray-600 mt-2">Ingredientes x prodcuto</div>
                </div>
                <div class="bg-white rounded-xl p-6 text-center shadow-sm">
                  <div class="text-3xl font-bold text-amber-300">5 años</div>
                  <div class="text-sm text-gray-600 mt-2">En el mercado</div>
                </div>
                <div class="bg-white rounded-xl p-6 text-center shadow-sm">
                  <div class="md:text-2xl font-bold sm:text-1xl text-amber-300">Sabiduria global</div>
                  <div class="text-sm text-gray-600 mt-2">Recetas familiares</div>
                </div>
              </div>
            </div>
          </div>
        </div>
         <div class="lg:ml-20 sm:ml-0 flex flex-wrap lg:gap-16 sm:gap-8 pt-4">
                <div class="flex items-center gap-1">
                  <span class="text-2xl">🌱</span>
                  <span class="text-sm font-medium text-gray-800"
                    >Ingredientes naturales</span
                  >
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-2xl">🔬</span>
                  <span class="text-sm font-medium text-gray-800"
                    >Respaldado por investigación</span
                  >
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-2xl">🧂</span>
                  <span class="text-sm font-medium text-gray-800"
                    >Cero aditivos</span
                  >
                </div>
                <div class="flex items-center gap-1"">
                  <span class="text-2xl">🤝</span>
                  <span class="text-sm font-medium text-gray-800"
                    >Confianza total</span
                  >
                </div>
              </div>
      </div>

    </section>

       <!-- Featured products section -->
    <FeaturedProducts />

    <!-- ===========================
       BENEFITS SECTION
       =========================== -->
    <section
      class="bg-gradient-to-bl from-green-300 to-yellow-200 px-4 py-16"
      aria-labelledby="benefits-heading"
    >
      <div class="mx-auto max-w-6xl">
        <div class="mb-12 text-center">
          <p class="text-5xl text-white font-bold pb-10">
            Sabiduria tradicional, Beneficios modernos
          </p>
          <Text type="body" color={colors.gray} className="mx-auto max-w-2xl">
            El conociemiento actual sigue confirmando el poder contenido en los ingredientes naturales tradicionales con efectos que  mejoran la calidad de vida, <strong>la nutricion es la mejor medicina.</strong>
          </Text>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <GoldBenefits />
          <ProtBenefits />
        </div>
      </div>
    </section>

    <!-- ===========================
       WHY CHOOSE US SECTION
       =========================== -->
    <section
      class="bg-gradient-to-br from-green-50 via-white to-amber-50 px-4 py-16"
      aria-labelledby="why-choose-heading"
    >
      <div class="mx-auto max-w-6xl">
        <div class="text-center mb-12">
          <Text
            type="h2"
            color={colors.dark}
            className="mb-3"
            id="why-choose-heading"
          >
            Nuestra promesa
          </Text>
          <Text type="body" color={colors.gray} className="mx-auto max-w-2xl">
            Entregamos la mejor combinacion de ingredientes naturales para ayudar a sentirse mejor.
          </Text>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {
            promises.map(({ icon, title, text }) => (
              <div class="bg-white rounded-xl border border-gray-100 p-8 shadow-md transition-all duration-300 hover:-translate-y-1 hover:border-green-500 hover:shadow-xl">
                <div class="text-4xl mb-4">{icon}</div>
                <h3 class="text-xl font-bold text-gray-900 mb-3">{title}</h3>
                <p class="text-gray-600 leading-relaxed">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Footer -->
    <Footer />
  </Hero>
</Layout>
